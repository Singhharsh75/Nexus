{
  "compilerOptions": {
    "target": "ES2022",
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "skipLibCheck": true,
    "outDir": "./dist"
  },
  "include": ["**/*.ts", "../src/lib/ai/**/*.ts"],
  "exclude": ["node_modules", "dist"]
}
